# Copy to .env.local for local development (Next.js loads .env.local automatically).
# Never commit real secrets.

# -----------------------------------------------------------------------------
# Firebase (client SDK) — from Firebase Console > Project settings > Your apps
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Publishable key (safe to expose in the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret key — server only (API routes, stripeService)
STRIPE_SECRET_KEY=

# -----------------------------------------------------------------------------
# App URL — used for Stripe return URLs (see src/lib/stripeService.ts)
# Example: https://www.lazybreadpdx.com  (no trailing slash)
# -----------------------------------------------------------------------------
HOSTNAME=http://localhost:3000

# -----------------------------------------------------------------------------
# Google reCAPTCHA — Email signup modal + server verification
# -----------------------------------------------------------------------------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
GOOGLE_CAPTCHA_SECRET_KEY=

# -----------------------------------------------------------------------------
# Datadog RUM (optional — layout.tsx)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DD_RUM_APPLICATION_ID=
NEXT_PUBLIC_DD_RUM_CLIENT_TOKEN=
NEXT_PUBLIC_DD_ENV=development
NEXT_PUBLIC_DD_VERSION=

# -----------------------------------------------------------------------------
# Runtime config JSON (optional — see src/lib/configService.ts)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CONFIG_S3_URL=
